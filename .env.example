# Copy this file to .env.local and fill in exactly one provider.
# The format is shell-compatible so run_dashboard.sh and serve_dashboard.py can read it.

LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash

# Optional alternatives
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini

# Generic provider example
# LLM_PROVIDER=generic
# LLM_API_KEY=
# LLM_API_URL=
# LLM_MODEL=custom-model
# LLM_API_FORMAT=messages

# Kakao-compatible provider example
# LLM_PROVIDER=kakao
# KAKAO_API_KEY=
# KAKAO_API_URL=
# KAKAO_MODEL=kakao-custom
